# Khetwala App Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# EXPO_PUBLIC_* variables are embedded at build time by Expo CLI.
#
# For USB/ADB debugging with Android emulator:  http://10.0.2.2:8000
# For WiFi (real device):  http://<your-LAN-IP>:8000
# For production:  https://your-backend-domain.com
#
# The app has full offline fallback—if this URL is unreachable, cached/mock
# data is used automatically.
EXPO_PUBLIC_BACKEND_URL=http://10.0.2.2:8000

# Optional: Google Maps / Places API key for Schemes & nearby maps
# EXPO_PUBLIC_GOOGLE_API_KEY=

# Optional: Grok / xAI API key (used by ARIA AI assistant)
# EXPO_PUBLIC_GROK_API_KEY=
